<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:OtcDataService.ViewModels"
             x:Class="OtcDataService.Views.SettingsView"
             x:DataType="vm:SettingsViewModel"
             Background="{StaticResource PageBackgroundBrush}">

  <Grid Margin="24" RowDefinitions="*,Auto">
    <!-- Main left-right layout -->
    <Border Grid.Row="0" Classes="card" Padding="0" ClipToBounds="True">
      <Grid ColumnDefinitions="200,*">

        <!-- Left: navigation menu -->
        <Border Grid.Column="0"
                Background="{StaticResource PrimaryBlueLightBrush}"
                BorderBrush="{StaticResource BorderBlueBrush}"
                BorderThickness="0,0,1,0"
                CornerRadius="7,0,0,7"
                ClipToBounds="True"
                Padding="12,16">
          <DockPanel>
            <TextBlock DockPanel.Dock="Top"
                       Text="Menu"
                       FontSize="11"
                       FontWeight="SemiBold"
                       Foreground="{StaticResource TextSecondaryBrush}"
                       Margin="6,0,0,12"
                       LetterSpacing="1" />
            <StackPanel Spacing="4">
              <Button Content="Database"
                      Classes="sideNav"
                      Classes.selected="{Binding IsDatabaseSelected}"
                      Command="{Binding SelectDatabaseCommand}" />
              <Button Content="Export"
                      Classes="sideNav"
                      Classes.selected="{Binding IsExportSelected}"
                      Command="{Binding SelectExportCommand}" />
            </StackPanel>
          </DockPanel>
        </Border>

        <!-- Right: settings content -->
        <Border Grid.Column="1"
                Background="{StaticResource SurfaceWhiteBrush}"
                CornerRadius="0,7,7,0"
                ClipToBounds="True">
          <DockPanel>
          <Border DockPanel.Dock="Top"
                  BorderBrush="{StaticResource BorderBlueBrush}"
                  BorderThickness="0,0,0,1"
                  Padding="24,18">
            <TextBlock Text="{Binding SelectedSectionTitle}"
                       Classes="sectionTitle" />
          </Border>

          <ScrollViewer HorizontalScrollBarVisibility="Disabled"
                        VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="24,20,24,32" IsEnabled="{Binding AreSettingsEditable}">
              <ContentControl Content="{Binding SelectedSectionContent}"
                              HorizontalAlignment="Stretch"
                              HorizontalContentAlignment="Stretch" />
            </StackPanel>
          </ScrollViewer>
          </DockPanel>
        </Border>
      </Grid>
    </Border>

    <!-- Bottom action bar -->
    <Border Grid.Row="1"
            Margin="0,16,0,0"
            Background="{StaticResource SurfaceWhiteBrush}"
            BorderBrush="{StaticResource BorderBlueBrush}"
            BorderThickness="1"
            CornerRadius="8"
            Padding="16,12">
      <Grid ColumnDefinitions="*,Auto">
        <TextBlock Text="{Binding StatusMessage}"
                   VerticalAlignment="Center"
                   Foreground="{StaticResource TextSecondaryBrush}"
                   FontSize="13"
                   TextWrapping="Wrap" />
        <StackPanel Grid.Column="1"
                    Orientation="Horizontal"
                    Spacing="8">
          <Button Content="Back"
                  Classes="secondary"
                  Command="{Binding BackCommand}" />
          <Button Content="Cancel"
                  Classes="secondary"
                  IsEnabled="{Binding AreSettingsEditable}"
                  Command="{Binding CancelCommand}" />
          <Button Content="Save"
                  Classes="primary"
                  IsEnabled="{Binding AreSettingsEditable}"
                  Command="{Binding SaveCommand}" />
        </StackPanel>
      </Grid>
    </Border>
  </Grid>
</UserControl>
