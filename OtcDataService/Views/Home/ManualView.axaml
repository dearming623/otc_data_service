<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:OtcDataService.ViewModels"
             x:Class="OtcDataService.Views.Home.ManualView"
             x:DataType="vm:ManualViewModel">

  <StackPanel Spacing="20" MaxWidth="560">
    <TextBlock Text="Export sales data for the selected date range to a catalog CSV file."
               Foreground="{StaticResource TextSecondaryBrush}"
               FontSize="13"
               TextWrapping="Wrap" />

    <StackPanel Spacing="14">
      <StackPanel Spacing="6">
        <TextBlock Text="Start date" Classes="formLabel" />
        <DatePicker SelectedDate="{Binding StartDate}"
                    IsEnabled="{Binding IsDateInputEnabled}"
                    Width="300"
                    HorizontalAlignment="Left" />
      </StackPanel>

      <StackPanel Spacing="6">
        <TextBlock Text="End date" Classes="formLabel" />
        <DatePicker SelectedDate="{Binding EndDate}"
                    IsEnabled="{Binding IsDateInputEnabled}"
                    Width="300"
                    HorizontalAlignment="Left" />
        <TextBlock Text="Date range is based on Sales lookback days in Export settings."
                   Foreground="{StaticResource TextSecondaryBrush}"
                   FontSize="12"
                   TextWrapping="Wrap" />
      </StackPanel>
    </StackPanel>

    <TextBlock Text="Export may take a few minutes depending on sales lookback days and database speed."
               Foreground="{StaticResource TextSecondaryBrush}"
               FontSize="12"
               TextWrapping="Wrap" />

    <Button Content="{Binding ExportButtonText}"
            Classes="primary"
            HorizontalAlignment="Left"
            Command="{Binding ExportNowCommand}" />

    <ProgressBar IsIndeterminate="{Binding IsExporting}"
                 IsVisible="{Binding IsExporting}"
                 Height="8"
                 MinHeight="8"
                 Width="300"
                 HorizontalAlignment="Left"
                 Foreground="{StaticResource PrimaryBlueBrush}"
                 Background="{StaticResource PrimaryBlueLightBrush}" />

    <TextBlock Text="{Binding StatusMessage}"
               Foreground="{StaticResource TextSecondaryBrush}"
               FontSize="13"
               TextWrapping="Wrap"
               IsVisible="{Binding StatusMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />
  </StackPanel>
</UserControl>
