<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:OtcDataService.ViewModels"
             x:Class="OtcDataService.Views.Home.ManualView"
             x:DataType="vm:ManualViewModel">

  <StackPanel Spacing="20">
    <TextBlock Text="Export today's sales data to a catalog CSV file."
               Foreground="{StaticResource TextSecondaryBrush}"
               FontSize="13"
               TextWrapping="Wrap" />

    <Button Content="Export Now"
            Classes="primary"
            HorizontalAlignment="Left"
            Command="{Binding ExportNowCommand}"
            IsEnabled="{Binding !IsExporting}" />

    <TextBlock Text="{Binding StatusMessage}"
               Foreground="{StaticResource TextSecondaryBrush}"
               FontSize="13"
               TextWrapping="Wrap"
               IsVisible="{Binding StatusMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />
  </StackPanel>
</UserControl>
