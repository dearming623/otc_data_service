<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:OtcDataService.ViewModels"
        x:Class="OtcDataService.Views.ExitPasswordDialog"
        x:DataType="vm:ExitPasswordDialogViewModel"
        Title="{Binding Title}"
        Width="400"
        SizeToContent="Height"
        CanResize="False"
        ShowInTaskbar="False"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource PageBackgroundBrush}">

  <Border Padding="24"
          Background="{StaticResource SurfaceWhiteBrush}"
          BorderBrush="{StaticResource BorderBlueBrush}"
          BorderThickness="1"
          CornerRadius="{StaticResource CardRadius}"
          Margin="16">
    <StackPanel Spacing="20">
      <TextBlock Text="{Binding Prompt}"
                 Foreground="{StaticResource TextSecondaryBrush}"
                 FontSize="13"
                 TextWrapping="Wrap" />

      <StackPanel Spacing="6">
        <TextBlock Text="Password" Classes="formLabel" />
        <Grid>
          <TextBox x:Name="PasswordBox"
                   Text="{Binding Password}"
                   PasswordChar="●"
                   Focusable="True"
                   Classes="appInput"
                   Padding="10,8,36,8" />
          <Button Classes="inputClear"
                  HorizontalAlignment="Right"
                  VerticalAlignment="Center"
                  Margin="0,0,8,0"
                  IsVisible="{Binding Password, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                  Command="{Binding ClearPasswordCommand}">
            <Path Width="8"
                  Height="8"
                  Stretch="Uniform"
                  Stroke="{StaticResource TextSecondaryBrush}"
                  StrokeThickness="1.2"
                  StrokeLineCap="Round"
                  Data="M1,1 L7,7 M7,1 L1,7" />
          </Button>
        </Grid>
      </StackPanel>

      <StackPanel Orientation="Horizontal"
                  HorizontalAlignment="Right"
                  Spacing="8">
        <Button Content="Cancel"
                Classes="secondary"
                Command="{Binding CancelCommand}" />
        <Button Content="Confirm"
                Classes="primary"
                IsVisible="{Binding IsPasswordValid}"
                Command="{Binding ConfirmCommand}" />
      </StackPanel>
    </StackPanel>
  </Border>
</Window>
