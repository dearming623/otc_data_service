<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:OtcDataService.ViewModels"
             x:Class="OtcDataService.Views.HomeView"
             x:DataType="vm:HomeViewModel"
             Background="{StaticResource PageBackgroundBrush}">

  <Grid Margin="24">
    <Border Classes="card" Padding="0" ClipToBounds="True">
      <Grid ColumnDefinitions="200,*">

        <!-- Left: feature menu -->
        <Border Grid.Column="0"
                Background="{StaticResource PrimaryBlueLightBrush}"
                BorderBrush="{StaticResource BorderBlueBrush}"
                BorderThickness="0,0,1,0"
                CornerRadius="7,0,0,7"
                ClipToBounds="True"
                Padding="12,16">
          <DockPanel>
            <TextBlock DockPanel.Dock="Top"
                       Text="Menu"
                       FontSize="11"
                       FontWeight="SemiBold"
                       Foreground="{StaticResource TextSecondaryBrush}"
                       Margin="6,0,0,12"
                       LetterSpacing="1" />
            <StackPanel Spacing="4">
              <Button Content="Activity Log"
                      Classes="sideNav"
                      Classes.selected="{Binding IsActivityLogSelected}"
                      Command="{Binding SelectActivityLogCommand}" />
              <Button Content="Manual"
                      Classes="sideNav"
                      Classes.selected="{Binding IsManualSelected}"
                      Command="{Binding SelectManualCommand}" />
            </StackPanel>
          </DockPanel>
        </Border>

        <!-- Right: section content -->
        <Border Grid.Column="1"
                Background="{StaticResource SurfaceWhiteBrush}"
                CornerRadius="0,7,7,0"
                ClipToBounds="True">
          <DockPanel>
            <Border DockPanel.Dock="Top"
                    BorderBrush="{StaticResource BorderBlueBrush}"
                    BorderThickness="0,0,0,1"
                    Padding="24,18">
              <TextBlock Text="{Binding SelectedSectionTitle}"
                         Classes="sectionTitle" />
            </Border>

            <ContentControl Content="{Binding SelectedSectionContent}"
                            HorizontalAlignment="Stretch"
                            HorizontalContentAlignment="Stretch"
                            Margin="24,20,24,32" />
          </DockPanel>
        </Border>
      </Grid>
    </Border>
  </Grid>
</UserControl>
