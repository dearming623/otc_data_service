<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:OtcDataService.ViewModels"
             x:Class="OtcDataService.Views.Settings.ExportSettingsView"
             x:DataType="vm:ExportSettingsViewModel">

  <StackPanel Spacing="20" MaxWidth="560">
    <TextBlock Text="Configure how often sales data is exported and where files are saved."
               Foreground="{StaticResource TextSecondaryBrush}"
               FontSize="13"
               TextWrapping="Wrap" />

    <CheckBox Content="Start with Windows"
              IsChecked="{Binding RunAtStartup}"
              ToolTip.Tip="Launch minimized to the system tray when you sign in to Windows." />

    <StackPanel Spacing="14">
      <StackPanel Spacing="6">
        <TextBlock Text="Sales lookback days" Classes="formLabel" />
        <NumericUpDown Minimum="1"
                       Maximum="3650"
                       Value="{Binding SalesLookbackDays}"
                       Classes="appInput"
                       Width="160"
                       HorizontalAlignment="Left" />
        <TextBlock Text="Number of past days of CleanupTrn sales (cu_trn_type=P) to include in each catalog export."
                   Foreground="{StaticResource TextSecondaryBrush}"
                   FontSize="12" />
      </StackPanel>

      <StackPanel Spacing="6">
        <TextBlock Text="Document interval days" Classes="formLabel" />
        <NumericUpDown Minimum="1"
                       Maximum="365"
                       Value="{Binding DocumentIntervalDays}"
                       Classes="appInput"
                       Width="160"
                       HorizontalAlignment="Left" />
        <TextBlock Text="How often a new export document is generated."
                   Foreground="{StaticResource TextSecondaryBrush}"
                   FontSize="12" />
      </StackPanel>

      <StackPanel Spacing="6">
        <TextBlock Text="Output folder" Classes="formLabel" />
        <Grid ColumnDefinitions="*,Auto">
          <TextBox Grid.Column="0"
                   Text="{Binding OutputFolder}"
                   Classes="appInput" />
          <Button Grid.Column="1"
                  Margin="8,0,0,0"
                  Content="Browse"
                  Classes="secondary"
                  Click="OnBrowseClick" />
        </Grid>
        <TextBlock Text="Local folder where CSV files are saved before optional remote upload."
                   Foreground="{StaticResource TextSecondaryBrush}"
                   FontSize="12" />
      </StackPanel>

      <Border BorderBrush="{StaticResource BorderBlueBrush}"
              BorderThickness="1"
              CornerRadius="8"
              Padding="14"
              Margin="0,4,0,0">
        <StackPanel Spacing="14">
          <CheckBox Content="Upload CSV after export"
                    IsChecked="{Binding FtpUploadEnabled}" />

          <StackPanel Spacing="14" IsEnabled="{Binding FtpUploadEnabled}">
            <StackPanel Spacing="6">
              <TextBlock Text="Protocol" Classes="formLabel" />
              <ComboBox ItemsSource="{Binding ProtocolOptions}"
                        SelectedItem="{Binding SelectedProtocolOption}"
                        DisplayMemberBinding="{Binding Display}"
                        Classes="appInput"
                        HorizontalAlignment="Stretch" />
            </StackPanel>

            <StackPanel Spacing="6">
              <TextBlock Text="Logon Type" Classes="formLabel" />
              <ComboBox ItemsSource="{Binding LogonTypeOptions}"
                        SelectedItem="{Binding SelectedLogonTypeOption}"
                        DisplayMemberBinding="{Binding Display}"
                        Classes="appInput"
                        HorizontalAlignment="Stretch" />
            </StackPanel>

            <StackPanel Spacing="6">
              <TextBlock Text="Host" Classes="formLabel" />
              <TextBox Text="{Binding FtpHost}"
                       Classes="appInput"
                       Watermark="e.g. ftp.example.com" />
            </StackPanel>

            <StackPanel Spacing="6">
              <TextBlock Text="Port" Classes="formLabel" />
              <NumericUpDown Minimum="1"
                             Maximum="65535"
                             Value="{Binding FtpPort}"
                             Classes="appInput"
                             Width="160"
                             HorizontalAlignment="Left" />
            </StackPanel>

            <StackPanel Spacing="6" IsVisible="{Binding IsFtpProtocol}">
              <TextBlock Text="Encryption" Classes="formLabel" />
              <ComboBox ItemsSource="{Binding EncryptionOptions}"
                        SelectedItem="{Binding SelectedEncryptionOption}"
                        DisplayMemberBinding="{Binding Display}"
                        Classes="appInput"
                        HorizontalAlignment="Stretch" />
            </StackPanel>

            <StackPanel Spacing="6" IsVisible="{Binding IsNormalLogon}">
              <TextBlock Text="Username" Classes="formLabel" />
              <TextBox Text="{Binding FtpUserName}" Classes="appInput" />
            </StackPanel>

            <StackPanel Spacing="6" IsVisible="{Binding IsNormalLogon}">
              <TextBlock Text="Password" Classes="formLabel" />
              <TextBox Text="{Binding FtpPassword}" Classes="appInput" PasswordChar="●" />
            </StackPanel>

            <StackPanel Spacing="6">
              <TextBlock Text="Remote path" Classes="formLabel" />
              <TextBox Text="{Binding FtpRemotePath}"
                       Classes="appInput"
                       Watermark="e.g. /exports" />
              <TextBlock Text="Remote directory on the server. The directory is created if it does not exist."
                         Foreground="{StaticResource TextSecondaryBrush}"
                         FontSize="12" />
            </StackPanel>

            <Button Content="Test Connection"
                    Classes="primary"
                    HorizontalAlignment="Left"
                    Command="{Binding TestFtpConnectionCommand}" />
          </StackPanel>
        </StackPanel>
      </Border>
    </StackPanel>
    
    <TextBlock Text="{Binding StatusMessage}"
               Foreground="{StaticResource PrimaryBlueBrush}"
               FontSize="13"
               TextWrapping="Wrap"
               IsVisible="{Binding StatusMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />
  </StackPanel>
</UserControl>
